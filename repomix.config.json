{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml"
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "node_modules/**",
      ".expo/**",
      "dist/**",
      "web-build/**",
      "*.lock",
      "package-lock.json",
      "pnpm-lock.yaml",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.ico",
      "*.svg",
      "*.woff",
      "*.woff2",
      "*.ttf",
      "*.eot",
      "*.mp4",
      "*.webm",
      ".git/**",
      ".gemini/**",
      "repomix-output.*",
      "android/**",
      "ios/**",
      "*.map",
      "_v0_data/**",
      "supabase/**"
    ]
  }
}
